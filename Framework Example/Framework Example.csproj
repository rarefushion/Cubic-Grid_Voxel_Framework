<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <Content Include="../Cubic-Grid_Voxel_Renderer/GLSL/**" CopyToOutputDirectory="PreserveNewest">
      <TargetPath>Assets\GLSL\%(Filename)%(Extension)</TargetPath>
    </Content>
    <Content Include="Assets\**" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Framework\GalensUnified.CubicGrid.Framework.csproj" />
    <ProjectReference Include="..\Cubic-Grid_Voxel_Renderer\C# Wrapper\GalensUnified.CubicGrid.Renderer.NET.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Silk.NET" Version="2.23.0" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Framework_Example</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

</Project>
